            },
            "url": {
              "raw": "{{baseUrl}}/movies/1",
              "host": ["{{baseUrl}}"],
              "path": ["movies", "1"]
            }
          }
        },
        {
          "name": "Update Movie (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 9.5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/movies/1",
              "host": ["{{baseUrl}}"],
              "path": ["movies", "1"]
            }
          }
        },
        {
          "name": "Delete Movie",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/movies/1",
              "host": ["{{baseUrl}}"],
              "path": ["movies", "1"]
            }
          }
        }
      ]
